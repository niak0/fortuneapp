rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı yalnızca kendi dokümanını ve fal alt koleksiyonunu yönetebilir.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /fortunes/{fortuneId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // Günlük burçlar: giriş yapmış herkes okur; yazma yalnızca sunucu
    // (Cloud Function admin SDK ile yazar ve kuralları bypass eder).
    match /dailyHoroscopes/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Tanımlı olmayan her yol reddedilir.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
